# URL du backend FastAPI
# Dev  : laisser vide (proxy Vite vers localhost:8000 par défaut)
# Prod : définir l'URL publique de l'API (ex: https://api.mondomaine.com)
VITE_API_BASE_URL=

# Modèle NLP utilisé pour /predict
# "baseline" → TF-IDF + LR (Render slim, CPU only)
# "distilbert" → DistilBERT fine-tuned (requiert le modèle dans models/fine_tuned/)
VITE_MODEL_TYPE=baseline
