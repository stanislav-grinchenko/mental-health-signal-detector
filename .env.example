# ----------------------------------------------------------------
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env (déjà dans .gitignore).
# ----------------------------------------------------------------

# Reddit API (PRAW) — à remplir pour l'ingestion live
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=mh-detector/1.0 by /u/your_username

# Base de données
# Développement : SQLite (aucune installation requise)
DATABASE_URL=sqlite:///./mhdetector.db
# Production : PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/mhdetector

# Modèle
MODEL_NAME=distilbert-base-uncased
MODEL_PATH=./models/fine_tuned

# Environnement : development | production
ENV=development
LOG_LEVEL=INFO

# CORS — origines autorisées (séparées par des virgules, sans espace)
# Laisser "*" en dev. En prod, mettre l'URL Vercel de votre app.
# Ex: ALLOWED_ORIGINS=https://monapp.vercel.app
ALLOWED_ORIGINS=*
